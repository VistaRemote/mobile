{
  "name": "@vistaremote/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "VistaRemote mobile controller (React Native)",
  "scripts": {
    "start": "node scripts/start-with-env.mjs",
    "start:metro": "react-native start",
    "android": "react-native run-android",
    "android:apk": "cd android && gradlew.bat assembleDebug",
    "setup": "node scripts/setup-dev.mjs",
    "test": "rstest",
    "test:watch": "rstest -w",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "tsc --noEmit",
    "prepare": "node ../tooling/scripts/setup-husky.mjs"
  },
  "dependencies": {
    "@vistaremote/shared": "file:../shared",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-webrtc": "^124.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@react-native/babel-preset": "0.76.6",
    "@react-native/metro-config": "0.76.6",
    "@react-native/typescript-config": "0.76.6",
    "@rstest/core": "^0.10.2",
    "@types/react": "^18.3.18",
    "husky": "^9.1.7",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
